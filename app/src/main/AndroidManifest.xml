<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Internet for Firebase, Billing -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Usage Stats Access (Requires user grant via Settings) -->
    <uses-permission
        android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />

    <!-- Run background tasks after boot -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Listen for unlocks -->
    <uses-permission android:name="android.permission.READ_PHONE_STATE" tools:ignore="ProtectedPermissions" /> <!-- Needed for USER_PRESENT on some older APIs? Test -->

    <!-- Accessibility Service (Requires user grant via Settings) -->
    <uses-permission android:name="android.permission.BIND_ACCESSIBILITY_SERVICE"
        tools:ignore="ProtectedPermissions" />

    <!-- Needed by ConfirmationActivity started from Service -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" /> <!-- If needed for overlay-like behavior, requires grant -->


    <!-- Post Notifications (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>

    <!-- Billing -->
    <uses-permission android:name="com.android.vending.BILLING" />


    <application
        android:name=".UnswipeApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Unswipe"
        tools:targetApi="31">
        <!-- Reference your base Splash/App theme -->


        <activity
        android:name=".ui.MainActivity"
        android:exported="true"
        android:theme="@style/Theme.Unswipe">
        <!-- Ensure Activity theme matches -->
        <intent-filter>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent-filter>
    </activity>

    <!-- Confirmation Dialog Activity -->
    <activity
        android:name=".ui.confirmation.ConfirmationActivity"
        android:theme="@style/Theme.Unswipe.DialogActivity"
        android:exported="true"
        android:launchMode="singleInstance"
        android:excludeFromRecents="true"
        android:taskAffinity=""
        android:showOnLockScreen="true" />

    <!-- Accessibility Service Declaration -->
    <service
        android:name=".data.services.SwipeAccessibilityService"
        android:exported="false"
        android:label="@string/accessibility_service_label"
        android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
        <intent-filter>
            <action android:name="android.accessibilityservice.AccessibilityService" />
        </intent-filter>
        <meta-data
            android:name="android.accessibilityservice"
            android:resource="@xml/accessibility_service_config" />
    </service>

    <!-- Unlock Receiver -->
    <receiver
        android:name=".data.receivers.UnlockReceiver"
        android:exported="false">
        <intent-filter>
            <!-- Listen for user presenting screen (unlock) -->
            <action android:name="android.intent.action.USER_PRESENT" />
            <!-- Optional: Listen for boot to potentially reschedule alarms/workers if needed -->
            <action android:name="android.intent.action.BOOT_COMPLETED" />
        </intent-filter>
    </receiver>

    <!-- Hilt-WorkManager Initializer -->
    <provider
        android:name="androidx.startup.InitializationProvider"
        android:authorities="${applicationId}.androidx-startup"
        android:exported="false"
        tools:node="merge">
        <meta-data
            android:name="androidx.work.WorkManagerInitializer"
            android:value="androidx.startup"
            tools:node="remove" />
    </provider>

    <!-- Add Firebase Service declarations if using FCM etc. -->

</application>

    </manifest>