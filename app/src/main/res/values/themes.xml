<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Starting Theme for Splash Screen -->
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <!-- Set the splash screen background -->
        <item name="windowSplashScreenBackground">@color/splash_background</item> <!-- Define splash_background in colors.xml -->
        <!-- Set the splash screen icon -->
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item> <!-- Or your custom splash icon -->
        <!-- Set the theme of the Activity that directly follows your splash screen -->
        <item name="postSplashScreenTheme">@style/Theme.Unswipe</item>
         <!-- Optional: Set status bar / navigation bar color during splash -->
         <item name="android:statusBarColor" tools:targetApi="l">@color/splash_background</item>
         <item name="android:navigationBarColor" tools:targetApi="l">@color/splash_background</item>
         <item name="android:windowLightStatusBar" tools:targetApi="m">true</item> <!-- Adjust based on splash background color -->
    </style>


    <!-- Base application theme. -->
    <style name="Theme.Unswipe" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light/dark theme attributes here. -->
        <!-- Example:
        <item name="colorPrimary">@color/md_theme_light_primary</item>
        <item name="colorOnPrimary">@color/md_theme_light_onPrimary</item>
        <item name="colorPrimaryContainer">@color/md_theme_light_primaryContainer</item>
        <item name="colorOnPrimaryContainer">@color/md_theme_light_onPrimaryContainer</item>
        ... other Material 3 colors ...
        -->

         <!-- Status bar/Navigation bar styling for the main app -->
         <item name="android:statusBarColor">@android:color/transparent</item>
         <item name="android:navigationBarColor">@android:color/transparent</item>
         <!-- Make status bar icons dark on light background / light on dark background -->
         <item name="android:windowLightStatusBar" tools:targetApi="m">@bool/use_light_status</item> <!-- Define use_light_status in values/bools.xml and values-night/bools.xml -->
         <!-- Ensure content draws behind system bars -->
         <item name="android:windowDrawsSystemBarBackgrounds">true</item>
         <!-- Could use EdgeToEdge library for easier handling -->

    </style>

    <!-- Theme for the Confirmation Activity to appear as a Dialog -->
    <style name="Theme.Unswipe.DialogActivity" parent="Theme.Material3.DayNight.Dialog.Alert">
         <!-- Inherits dialog styling from Material 3 -->
         <!-- Make it translucent and dialog-like -->
         <item name="android:windowIsTranslucent">true</item>
         <item name="android:windowBackground">@android:color/transparent</item>
         <item name="android:windowContentOverlay">@null</item>
         <item name="android:windowNoTitle">true</item>
         <item name="android:windowIsFloating">true</item>
         <item name="android:backgroundDimEnabled">true</item>
    </style>

    <!-- Alternative translucent theme if needed -->
    <style name="Theme.AppCompat.Translucent" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:backgroundDimEnabled">false</item>
    </style>

</resources> 